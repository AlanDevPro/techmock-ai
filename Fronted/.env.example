# ============================================================
# ENTORNO Y PUERTOS
# ============================================================
NODE_ENV=development
FRONTEND_PORT=3000

# ============================================================
# CONEXIONES DE APIS (Sufijo NEXT_PUBLIC_ para acceso en navegador)
# ============================================================
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_RAG_API_URL=http://localhost:8000

# ============================================================
# CONFIGURACIÓN CLIENTE DE FIREBASE (Autenticación Google, etc.)
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_numeric_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_sender_id:web:your_app_hash_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-YOURGA4ID