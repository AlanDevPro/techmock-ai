# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ============================================================
# DATABASE CONNECTIONS
# ============================================================
# Local o Docker (Cambiar host según entorno)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sistema_entrevistas
DB_USER=postgres
DB_PASSWORD=your_secure_password

# URL unificada utilizada por ORMs (Prisma, Sequelize, TypeORM, SQLalchemy)
DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_db_name

# ============================================================
# AUTHENTICATION (JWT)
# ============================================================
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_RESET_SECRET=your_jwt_reset_password_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# ARTIFICIAL INTELLIGENCE PROVIDERS
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
IA_MODEL=claude-sonnet-4-20250514

# ============================================================
# FIREBASE ADMIN SDK (Google OAuth)
# ============================================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_FAKE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================================
# KUBERNETES RUNNER CONFIGURATION
# ============================================================
K8S_NAMESPACE=techmock-jobs
K8S_RUNNER_JS=techmock-runner-js:latest
K8S_RUNNER_PY=techmock-runner-py:latest
K8S_RUNNER_JAVA=techmock-runner-java:latest
K8S_JOB_TIMEOUT_S=30
K8S_POLL_INTERVAL_MS=2000
K8S_MAX_POLLS=30

# ============================================================
# NETWORKING / CORS
# ============================================================
FRONTEND_URL=http://localhost:3000
PREVIEW_SERVER_URL=http://localhost:5050

# ============================================================
# MAILING SERVICES (SMTP / AWS SES)
# ============================================================
# Para desarrollo (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="TechMock AI <no-reply@techmock.ai>"

# Para producción (AWS SES)
AWS_REGION=us-east-1
SES_FROM_EMAIL=no-reply@yourdomain.com