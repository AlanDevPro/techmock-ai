# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5433/sistema_entrevistas

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# IA
ANTHROPIC_API_KEY=
IA_MODEL=claude-sonnet-4-20250514

# Kubernetes
K8S_NAMESPACE=techmock-jobs
K8S_RUNNER_IMAGE_JS=techmock/runner-js:latest
K8S_RUNNER_IMAGE_PY=techmock/runner-py:latest
K8S_JOB_TIMEOUT_MS=30000

# Preview server
PREVIEW_SERVER_URL=http://localhost:5050