# ============================================================
# .dockerignore — Archivos excluidos del contexto de build
# Reduce el tamaño de la imagen y evita filtrar secretos
# ============================================================

# Dependencias locales (se instalan dentro del contenedor)
node_modules/
npm-debug.log*

# Archivos de entorno con secretos reales
.env
.env.local
.env.docker
.env.*.local

# Control de versiones
.git/
.gitignore

# Documentación y configuración de editores
README.md
*.md
.vscode/
.idea/
*.swp
*.swo

# Archivos de test
**/__tests__/
**/*.test.js
**/*.spec.js
coverage/

# Archivos de Docker (no incluirlos dentro de la imagen)
Dockerfile*
docker-compose*.yml
docker/

# Sistema operativo
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Archivos temporales
tmp/
temp/