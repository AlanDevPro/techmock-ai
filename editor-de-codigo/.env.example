# ============================================================
# INTERFACES Y URLS PÚBLICAS (Sufijo NEXT_PUBLIC_ para el Navegador)
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000/api/v1
NEXT_PUBLIC_RAG_API_URL=http://localhost:8000/rag

# ============================================================
# AUTHENTICATION (NextAuth.js)
# ============================================================
# En producción debe coincidir exactamente con NEXT_PUBLIC_APP_URL
NEXTAUTH_URL=http://localhost:3000
# Generar clave segura con: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_minimum_32_characters

# ============================================================
# COMUNICACIÓN INTERNA DEL BACKEND (RAG & APIs)
# ============================================================
TECHMOCK_API_BASE_URL=http://localhost:4000
TECHMOCK_API_KEY=your_internal_secure_api_key

# ============================================================
# INFRAESTRUCTURA DE DESPLIEGUE (AWS ECR / Docker / DevOps)
# ============================================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your_aws_account_id
ECR_REGISTRY=your_account_id.dkr.ecr.your_region.amazonaws.com
ECR_REPOSITORY=techmock-editor
IMAGE_TAG=latest