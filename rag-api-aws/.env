# ============================================================
# RAG INTERVIEW API — Variables de entorno
# Copiar este archivo a .env y completar los valores reales.
# NUNCA commitear el .env con credenciales reales al repo.
# ============================================================


# ────────────────────────────────────────────────────────────
# APLICACIÓN
# ────────────────────────────────────────────────────────────

APP_NAME="RAG Interview API"
APP_VERSION="2.0.0"

# true  → habilita /docs, /redoc, /openapi.json, logs verbosos,
#         errores detallados en respuestas y endpoint /info
# false → producción (sin docs expuestos)
DEBUG=true


# ────────────────────────────────────────────────────────────
# BASE DE DATOS (PostgreSQL + asyncpg)
# ────────────────────────────────────────────────────────────

# Formato: postgresql+asyncpg://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql+asyncpg://postgres:alandevpro67656434@localhost:5433/sistema_entrevistas

# Ejemplos para otros entornos:
# AWS RDS:   postgresql+asyncpg://user:pass@rds-endpoint.amazonaws.com:5432/dbname
# Docker:    postgresql+asyncpg://postgres:postgres@db:5432/rag_interview_db
# Supabase:  postgresql+asyncpg://postgres:pass@db.project.supabase.co:5432/postgres


# ────────────────────────────────────────────────────────────
# LLM — PROVEEDOR ACTIVO
# Opciones: groq | openai | anthropic | ollama
# Solo se usa el proveedor configurado aquí; los demás son ignorados.
# ────────────────────────────────────────────────────────────

LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096


# ────────────────────────────────────────────────────────────
# LLM — GROQ
# Documentación: https://console.groq.com
# Modelos disponibles: llama-3.3-70b-versatile, mixtral-8x7b-32768
# ────────────────────────────────────────────────────────────

GROQ_API_KEY=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
GROQ_BASE_URL=https://api.groq.com/openai/v1


# ────────────────────────────────────────────────────────────
# LLM — OPENAI
# Documentación: https://platform.openai.com
# Modelos recomendados: gpt-4o, gpt-4o-mini, gpt-4-turbo
# ────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1


# ────────────────────────────────────────────────────────────
# LLM — ANTHROPIC
# Documentación: https://console.anthropic.com
# Modelos recomendados: claude-opus-4-6, claude-sonnet-4-6
# ────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ────────────────────────────────────────────────────────────
# LLM — OLLAMA (local / self-hosted)
# Documentación: https://ollama.com
# Modelos recomendados: llama3, mistral, deepseek-coder
# ────────────────────────────────────────────────────────────

OLLAMA_BASE_URL=http://localhost:11434


# ────────────────────────────────────────────────────────────
# EMBEDDINGS
# Opciones: openai | huggingface | cohere
# La dimensión DEBE coincidir con el índice OpenSearch.
# ────────────────────────────────────────────────────────────

EMBEDDING_PROVIDER=openai
# OpenAI:       text-embedding-3-small (1536) | text-embedding-3-large (3072)
# HuggingFace:  sentence-transformers/all-MiniLM-L6-v2 (384)
# Cohere:       embed-multilingual-v3.0 (1024)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536


# ────────────────────────────────────────────────────────────
# OPENSEARCH / RAG
# Documentación: https://opensearch.org
# ────────────────────────────────────────────────────────────

OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=rag-interview-docs

# Número de fragmentos a recuperar por búsqueda semántica (k-NN)
RAG_TOP_K=5

# Puntaje mínimo de similitud para incluir un fragmento (0.0 = sin filtro)
RAG_MIN_SCORE=0.0


# ────────────────────────────────────────────────────────────
# SEGURIDAD Y CORS
# ────────────────────────────────────────────────────────────

# Clave secreta para firmar JWT — CAMBIAR en producción
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_STRING

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Orígenes permitidos por CORS (lista separada por comas)
# Desarrollo local:
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:4173"]
# Producción (ejemplo):
# ALLOWED_ORIGINS=["https://app.tudominio.com","https://tudominio.com"]

# Hosts de confianza para TrustedHostMiddleware (solo aplica cuando DEBUG=false)
ALLOWED_HOSTS=["*"]
# Producción (ejemplo):
# ALLOWED_HOSTS=["api.tudominio.com","tudominio.com"]


# ────────────────────────────────────────────────────────────
# LÍMITES DE NEGOCIO
# ────────────────────────────────────────────────────────────

# Longitud máxima del código enviado por el candidato (caracteres)
MAX_CODIGO_LENGTH=50000
NIVEL_DEFAULT=Junior