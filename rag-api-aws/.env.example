# ============================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================================
APP_NAME="RAG Interview API"
APP_VERSION="2.0.0"
DEBUG=true

# ============================================================
# BASE DE DATOS (PostgreSQL con driver asyncpg)
# ============================================================
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ============================================================
# ORQUESTACIÓN DE LLM (groq | openai | anthropic | ollama)
# ============================================================
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Credenciales de Proveedores (Rellenar solo el activo)
GROQ_API_KEY=gsk_your_fake_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

OPENAI_API_KEY=sk-your-fake-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=sk-ant-your-fake-anthropic-key-here

OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# EMBEDDINGS (local | openai | huggingface | cohere)
# ============================================================
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768
HF_TOKEN=your_huggingface_token_here

# ============================================================
# VECTOR STORE (OpenSearch)
# ============================================================
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=rag-interview-docs
RAG_TOP_K=5
RAG_MIN_SCORE=0.0

# ============================================================
# SEGURIDAD, TOKENS Y CORS
# ============================================================
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_hex_secret_key_here
JWT_SECRET=your_jwt_signing_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Formato JSON string para arrays en Python
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
ALLOWED_HOSTS=["*"]

# ============================================================
# LÍMITES DE NEGOCIO
# ============================================================
MAX_CODIGO_LENGTH=50000
NIVEL_DEFAULT=Junior